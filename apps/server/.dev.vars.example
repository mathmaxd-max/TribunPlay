# Copy to .dev.vars in this directory for `wrangler dev` (gitignored).
# Production: use `wrangler secret put AUTH_TOKEN_SECRET` etc., and dashboard
# Variables / wrangler.jsonc for non-secret vars like TURNSTILE_ENABLED.

# Override production wrangler.jsonc vars for local dev:
TURNSTILE_ENABLED=false
# TURNSTILE_ENABLED=true
# TURNSTILE_SECRET_KEY=
# GOOGLE_CLIENT_ID=
AUTH_TOKEN_SECRET=

# Optional (dev/staging only): enables POST /api/admin/purge-local-accounts
# ADMIN_PURGE_KEY=
