# Copy this file to local.env (or any name) in this folder and fill in.
# local.env is gitignored. Apps do NOT load this file automatically—copy values
# into apps/web/.env.local and apps/server/.dev.vars when developing.

# --- Web (Vite) → apps/web/.env.local or Cloudflare Pages ---
VITE_API_BASE=
VITE_WS_BASE=
VITE_GOOGLE_CLIENT_ID=
VITE_TURNSTILE_SITE_KEY=

# --- Worker (local) → apps/server/.dev.vars ---
TURNSTILE_ENABLED=false
TURNSTILE_SECRET_KEY=
GOOGLE_CLIENT_ID=
AUTH_TOKEN_SECRET=
